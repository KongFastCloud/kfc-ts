{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@workspace/mastra/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts", "*.js"],
  "exclude": ["node_modules", "dist"]
}
