# ralphly environment variables
#
# Copy this file to .env and fill in your values, or export them directly
# in your shell profile.
#
# Environment variables override values in .ralphly/config.json.
# See the README for full precedence rules.

# Absolute path to the execution workspace ralphly operates in.
# (RALPHLY_REPO_PATH is accepted as a temporary backward-compatibility alias.)
RALPHLY_WORKSPACE_PATH=

# Linear API key for SDK authentication (starts with lin_api_).
LINEAR_API_KEY=

# Linear agent ID that ralphly operates as.
LINEAR_AGENT_ID=
