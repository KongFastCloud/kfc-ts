# Seer environment configuration
#
# Copy to .env.local and fill in values:
#   cp .env.example .env.local

# ── Server ───────────────────────────────────────────────────────
# Port for the HTTP server (default: 4320)
PORT=4320

# ── Repository Grounding ─────────────────────────────────────────
# Root of the repository checkout that seer should read and index.
# Defaults to the current working directory.
# SEER_REPO_ROOT=/absolute/path/to/repo
#
# Branch seer should sync and track for startup/webhook reindexing.
# Defaults to "main".
# SEER_TRACKED_BRANCH=main
#
# Optional custom path for the codemogger SQLite index database.
# If unset, codemogger uses its default location under the project.
# CODEMOGGER_DB_PATH=/absolute/path/to/codemogger.db

# ── AI Gateway ───────────────────────────────────────────────────
# Vercel AI Gateway (or compatible) base URL and API key.
# Used by @workspace/mastra for model routing.
AI_GATEWAY_BASE_URL=https://gateway.ai.vercel.app/v1
AI_GATEWAY_API_KEY=

# ── GlitchTip (MCP) ─────────────────────────────────────────────
# Credentials for the GlitchTip MCP integration.
# Used by @workspace/mastra/mcp to connect to GlitchTip for
# read-only issue and event inspection.
#
# GLITCHTIP_TOKEN        — (required) Personal API token.
# GLITCHTIP_ORGANIZATION — (required) Organization slug in GlitchTip.
# GLITCHTIP_BASE_URL     — (optional) Self-hosted instance URL.
#                           Defaults to https://app.glitchtip.com.
GLITCHTIP_TOKEN=
GLITCHTIP_ORGANIZATION=
# GLITCHTIP_BASE_URL=https://app.glitchtip.com

# ── Memory Storage ────────────────────────────────────────────────
# Local LibSQL database URL for durable memory persistence.
# Must be a local file: URL. Defaults to file:./data/memory.db
# SEER_MEMORY_DB_URL=file:./data/memory.db
